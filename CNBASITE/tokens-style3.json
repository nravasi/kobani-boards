  "shadows": {
    "sm": "0 1px 3px rgba(27, 58, 75, 0.06)",
    "md": "0 4px 12px rgba(27, 58, 75, 0.1)",
    "lg": "0 8px 24px rgba(27, 58, 75, 0.14)",
    "xl": "0 16px 40px rgba(27, 58, 75, 0.18)"
  },
  "transitions": {
    "fast": "180ms ease-in-out",
    "normal": "300ms ease-in-out",
    "slow": "500ms ease-in-out"
