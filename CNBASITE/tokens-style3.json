    "hero": {
      "background": "#1B3A4B",
      "textColor": "#FAF8F4",
      "subtitleColor": "#D6D0C4",
      "minHeight": "75vh",
      "headingSize": "4.25rem",
      "headingWeight": 700,
      "headingLineHeight": 1.15,
      "headingFontFamily": "'Playfair Display', Georgia, serif",
      "overlay": "linear-gradient(160deg, rgba(27, 58, 75, 0.88) 0%, rgba(15, 35, 48, 0.95) 100%)",
      "goldAccent": "1px solid #C8A951",
      "decorativeDivider": "#C8A951"
    }
  }
