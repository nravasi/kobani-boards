      "secondaryHoverBg": "#F0ECE3",
      "borderRadius": "0.375rem",
      "paddingX": "1.75rem",
      "paddingY": "0.8125rem",
      "fontSize": "0.875rem",
      "fontWeight": 600,
      "letterSpacing": "0.04em",
      "textTransform": "none",
      "goldVariantBg": "#C8A951",
      "goldVariantText": "#1B3A4B",
      "goldVariantHoverBg": "#D9C06E"
    },
    "card": {
      "background": "#FFFFFF",
      "border": "1px solid #D6D0C4",
      "borderRadius": "0.5rem",
      "shadow": "0 1px 3px rgba(27, 58, 75, 0.06)",
      "hoverShadow": "0 8px 24px rgba(27, 58, 75, 0.14)",
      "padding": "2rem",
      "gap": "1.25rem",
      "headerBorder": "2px solid #C8A951"
