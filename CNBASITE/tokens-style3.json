  "colors": {
    "primary": "#1B3A4B",
    "primaryLight": "#2A5572",
    "primaryDark": "#0F2330",
    "secondary": "#C8A951",
    "secondaryLight": "#D9C06E",
    "secondaryDark": "#A88C3A",
    "accent": "#8B2E3B",
    "accentLight": "#A63D4C",
    "accentDark": "#6E1F2D",
    "background": "#FAF8F4",
    "backgroundAlt": "#F0ECE3",
    "surface": "#FFFFFF",
    "surfaceElevated": "#FFFFFF",
    "surfaceDark": "#1B3A4B",
    "text": "#2C2C2C",
    "textSecondary": "#5A5A5A",
    "textOnPrimary": "#FAF8F4",
    "textOnSecondary": "#1B3A4B",
    "textMuted": "#8A8A8A",
