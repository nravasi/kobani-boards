      "4xl": "2.25rem",
      "5xl": "2.75rem",
      "6xl": "3.5rem",
      "7xl": "4.25rem"
    },
    "lineHeight": {
      "tight": 1.2,
      "snug": 1.35,
      "normal": 1.65,
      "relaxed": 1.8
